{
  "name": "opencode-chrome-bridge",
  "version": "1.4.1",
  "private": true,
  "description": "OpenCode plugin and local native bridge for controlling Google Chrome.",
  "type": "module",
  "main": "src/opencode-plugin.js",
  "exports": {
    ".": "./src/opencode-plugin.js"
  },
  "scripts": {
    "check": "node scripts/check-syntax.mjs",
    "check:chrome-extension": "node scripts/check-chrome-extension.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "install:native": "node scripts/install-native-host.mjs",
    "install:opencode": "node scripts/install-opencode-plugin.mjs",
    "setup:windows": "node scripts/setup-windows.mjs",
    "print:extension-id": "node scripts/print-extension-id.mjs",
    "scan:release": "node scripts/scan-release.mjs",
    "test": "node --test",
    "verify": "node scripts/verify.mjs",
    "smoke:native": "node scripts/smoke-native-host.mjs",
    "smoke:installed": "node scripts/smoke-installed-stack.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.17.20"
  },
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmgallardodev/opencode-chrome-bridge.git"
  },
  "homepage": "https://github.com/pmgallardodev/opencode-chrome-bridge#readme",
  "bugs": {
    "url": "https://github.com/pmgallardodev/opencode-chrome-bridge/issues"
  },
  "author": "pmgallardodev",
  "keywords": [
    "opencode",
    "chrome",
    "native-messaging",
    "browser-automation"
  ],
  "license": "MIT"
}
