{
  "manifest_version": 3,
  "name": "OpenCode Chrome Bridge",
  "description": "Let OpenCode inspect and control Chrome through a local native bridge.",
  "version": "1.4.3",
  "minimum_chrome_version": "116",
  "author": "pmgallardodev",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["images/cursor-chat.png"]
    }
  ],
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "action": {
    "default_title": "OpenCode Chrome Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src 'none';"
  },
  "storage": {
    "managed_schema": "managed_schema.json"
  },
  "permissions": [
    "alarms",
    "bookmarks",
    "debugger",
    "downloads",
    "downloads.ui",
    "history",
    "nativeMessaging",
    "notifications",
    "scripting",
    "storage",
    "tabGroups",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
